{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "dist",
    "rootDir": ".",
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["ui/**/*.ts"],
  "exclude": ["node_modules", "dist", "scraper"]
}
